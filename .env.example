# WOPI service — sample local configuration.
# Copy to .env.local and adjust; `make run` sources .env.local automatically when present.
#   cp .env.example .env.local
# Values below mirror the defaults in internal/config/config.go unless noted.
# Only WOPI_TOKEN_SECRET is strictly required; an auth transport (see below) is
# also required in practice.

# --- Own database (WOPI state: tokens, locks, sessions) -----------------------
WOPI_DATABASE_HOST=localhost
WOPI_DATABASE_PORT=5432
WOPI_DATABASE_USERNAME=synapse
WOPI_DATABASE_PASSWORD=synapse
WOPI_DATABASE_NAME=wopi
WOPI_DATABASE_TIMEOUT=5s

# --- Authorization-evaluation-service (set at least one transport) ------------
# h2c HTTP is preferred; NATS is the legacy fallback used only when AUTH_SERVICE_URL is empty.
# authorization-evaluation-service is published on the stable Traefik port 6060.
AUTH_SERVICE_URL=http://localhost:6060
# NATS_URL=nats://localhost:4222
# Circuit breaker (optional; defaults shown)
# AUTH_BREAKER_FAILURE_THRESHOLD=3
# AUTH_BREAKER_TIMEOUT_SECONDS=15
# AUTH_BREAKER_HALF_OPEN_MAX_REQUESTS=2

# # --- file-service (private cluster-internal endpoints) ------------------------
# Reach file-service through Traefik on the STABLE :3000 (the file-service-internal
# router proxies PathPrefix(/internal/file) → file-service). wopi only calls
# /internal/file/{id}/meta and /internal/file/{id}/content, both covered. This is
# the same pattern the Alkemio server uses — no ephemeral docker ports to chase.
FILE_SERVICE_URL=http://localhost:3000

# # --- Collabora Online ---------------------------------------------------------
# Reach Collabora through Traefik on the STABLE :3000 (routes /hosting/discovery,
# /browser, /cool). wopi only needs /hosting/discovery here.
WOPI_COLLABORA_URL=http://localhost:3000

# --- Service ------------------------------------------------------------------
# Browser-facing host for the editor iframe. buildEditorURL takes only the PATH
# from Collabora discovery and prepends this. The browser reaches Collabora via
# Traefik on :3000 (the dev collabora advertises localhost:3000 in discovery),
# so this must be :3000 — NOT :8080 (that's wopi-service, which 404s on /browser).
WOPI_BASE_URL=http://localhost:3000
# Collabora server-side callback (WOPISrc). Defaults to WOPI_BASE_URL when empty.
# Point at Traefik so the WOPISrc (http://traefik/wopi/files/...) rides the
# wopi-service failover: Traefik serves your local instance while it's up and
# falls back to the container when it's down. Only Collabora has to resolve
# `traefik` (it can); this service just builds the string.
WOPI_CALLBACK_URL=http://traefik
# Origin of the page embedding the editor iframe (WOPI PostMessageOrigin).
# Defaults to the origin of WOPI_BASE_URL when empty.
# WOPI_FRONTEND_ORIGIN=http://localhost:3000
WOPI_SERVER_PORT=8080

# REQUIRED — secret used to sign WOPI access tokens. Use a strong value in prod.
WOPI_TOKEN_SECRET=dev-wopi-token-secret-change-in-production

# Validate Collabora proof keys on every request. Default (and prod) is "true";
# this sample leaves it at the secure default. For local dev against the
# quickstart stack, set WOPI_PROOF_VALIDATION=false in your own .env.local to
# match the dev collabora (which runs with proof validation off).
# WOPI_PROOF_VALIDATION=false

# Hard upper bound on how long a single Collabora lockID may persist via repeated
# refreshes (0 disables the zombie-lock takeover defence). Default 4h.
# WOPI_MAX_LOCK_LIFETIME=4h
