# WOPI service — sample local configuration for the dev stack.
# Copy and run; `make run` sources .env.local automatically when present.
#   cp .env.example .env.local && make run
# These values work as-is against the local quickstart stack. Everything below
# the "Optional overrides" line has a working default and can stay untouched.

# --- Own database (WOPI state: tokens, locks, sessions) -----------------------
WOPI_DATABASE_HOST=localhost
WOPI_DATABASE_PORT=5432
WOPI_DATABASE_USERNAME=synapse
WOPI_DATABASE_PASSWORD=synapse
WOPI_DATABASE_NAME=wopi
WOPI_DATABASE_TIMEOUT=5s

# --- Authorization-evaluation-service ----------------------------------------
# h2c HTTP, published on the stable Traefik port 6060. (NATS is a legacy
# fallback used only when AUTH_SERVICE_URL is empty — see optional overrides.)
AUTH_SERVICE_URL=http://localhost:6060

# --- file-service (private cluster-internal endpoints) ------------------------
# Reach file-service through Traefik on the STABLE :3000 (the file-service-internal
# router proxies PathPrefix(/internal/file) → file-service). wopi only calls
# /internal/file/{id}/meta and /internal/file/{id}/content, both covered. This is
# the same pattern the Alkemio server uses — no ephemeral docker ports to chase.
FILE_SERVICE_URL=http://localhost:3000

# --- Collabora Online ---------------------------------------------------------
# Reach Collabora through Traefik on the STABLE :3000 (routes /hosting/discovery,
# /browser, /cool). wopi only needs /hosting/discovery here.
WOPI_COLLABORA_URL=http://localhost:3000

# --- Service ------------------------------------------------------------------
# Browser-facing host for the editor iframe. buildEditorURL takes only the PATH
# from Collabora discovery and prepends this. The browser reaches Collabora via
# Traefik on :3000 (the dev collabora advertises localhost:3000 in discovery),
# so this must be :3000 — NOT :8080 (that's wopi-service, which 404s on /browser).
WOPI_BASE_URL=http://localhost:3000
# Collabora server-side callback (WOPISrc). Point at Traefik so the WOPISrc
# (http://traefik/wopi/files/...) rides the wopi-service failover: Traefik serves
# your local instance while it's up and falls back to the container when it's down.
# Only Collabora has to resolve `traefik` (it can); this service just builds the string.
WOPI_CALLBACK_URL=http://traefik
WOPI_SERVER_PORT=8080

# REQUIRED — secret used to sign WOPI access tokens. Use a strong value in prod.
WOPI_TOKEN_SECRET=dev-wopi-token-secret-change-in-production

# The dev-stack collabora runs with proof signing OFF, so wopi must NOT validate
# proof keys or it rejects every Collabora callback (editor hangs on "Connecting
# to the collaboration service…"). 
# 
# WARNING: Omitting this variable defaults to TRUE (config.go). You must explicitly
# set it to "false" to disable validation. Keep this "true" in prod.
WOPI_PROOF_VALIDATION=false

# --- Optional overrides (working defaults; uncomment only to change) ----------
# NATS_URL=nats://localhost:4222          # auth fallback when AUTH_SERVICE_URL is empty
# AUTH_BREAKER_FAILURE_THRESHOLD=3
# AUTH_BREAKER_TIMEOUT_SECONDS=15
# AUTH_BREAKER_HALF_OPEN_MAX_REQUESTS=2
# WOPI_FRONTEND_ORIGIN=http://localhost:3000   # PostMessageOrigin; defaults to WOPI_BASE_URL origin
# WOPI_MAX_LOCK_LIFETIME=4h                # zombie-lock takeover bound (0 disables)
# RabbitMQ contribution-event publishing — analytics only; publisher no-ops if unset.
# RABBITMQ_HOST=localhost
# RABBITMQ_PORT=5672
# RABBITMQ_USER=alkemio-admin
# RABBITMQ_PASSWORD=alkemio!
# CONTRIBUTION_WINDOW=600s                 # aggregation window; default 600s
